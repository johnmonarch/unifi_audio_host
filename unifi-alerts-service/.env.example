TZ=America/New_York
# Paste-only Cosmos compose can point to GHCR images:
ALERTS_ADMIN_IMAGE=ghcr.io/your-github-user/unifi-alerts-admin:latest
ALERTS_WATCHER_IMAGE=ghcr.io/your-github-user/unifi-alerts-watcher:latest
# Leave blank to use web onboarding at /onboarding
HA_BASE_URL=
HA_TOKEN=
WATCHER_NAMES=zone1,zone2
ALERT_URL_BASE=http://your-docker-host:8125
FILE_MANAGER_URL=http://your-docker-host:8126
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Optional generic watcher defaults (used only when a zone is missing values in /config/alerts.json)
ALERT_SENSOR=
ALERT_PLAYER=
ALERT_URL=
ALERT_START_HHMM=0000
ALERT_END_HHMM=2359
ALERT_INTERVAL_SEC=120
ALERT_MIN_ON_SEC=5
ALERT_IDLE_POLL_SEC=5
ALERT_VOLUME=
ALERT_MEDIA_CONTENT_TYPE=music

# Zone 1 watcher
ZONE1_ALERT_SENSOR=binary_sensor.your_zone1_person_detected
ZONE1_ALERT_PLAYER=media_player.your_zone1_speaker
ZONE1_ALERT_URL=http://your-docker-host:8125/attention.aiff
ZONE1_ALERT_START_HHMM=2230
ZONE1_ALERT_END_HHMM=0600
ZONE1_ALERT_INTERVAL_SEC=120
ZONE1_ALERT_MIN_ON_SEC=5
ZONE1_ALERT_IDLE_POLL_SEC=5
ZONE1_ALERT_VOLUME=0.6
ZONE1_ALERT_MEDIA_CONTENT_TYPE=music

# Zone 2 watcher
ZONE2_ALERT_SENSOR=binary_sensor.your_zone2_person_detected
ZONE2_ALERT_PLAYER=media_player.your_zone2_speaker
ZONE2_ALERT_URL=http://your-docker-host:8125/attention.aiff
ZONE2_ALERT_START_HHMM=2230
ZONE2_ALERT_END_HHMM=0600
ZONE2_ALERT_INTERVAL_SEC=120
ZONE2_ALERT_MIN_ON_SEC=5
ZONE2_ALERT_IDLE_POLL_SEC=5
ZONE2_ALERT_VOLUME=0.6
ZONE2_ALERT_MEDIA_CONTENT_TYPE=music
